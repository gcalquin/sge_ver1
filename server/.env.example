PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Dejar vacío salvo que el servidor corra detrás de un reverse proxy/balanceador
# real (Nginx, Render, etc.). Con un solo proxy delante, usar "1".
TRUST_PROXY=

DATABASE_URL=postgresql://postgres:<password>@localhost:5432/SGE-BaseDeDatos

SESSION_SECRET=cambia-este-valor-por-un-secreto-largo-y-aleatorio

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
