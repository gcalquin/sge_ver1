{
  "name": "sge-server",
  "version": "2.0.0",
  "description": "Backend Node.js + PostgreSQL multi-colegio para el Sistema de Gestion de Casos Estudiantiles (SGE)",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/db/seed.js",
    "db:migrate": "node-pg-migrate up",
    "build:css": "tailwindcss -i ./public/css/tailwind-source.css -o ./public/css/tailwind.css --minify",
    "test": "vitest run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.2",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.4",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.6.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.10",
    "vitest": "^4.1.9"
  }
}
